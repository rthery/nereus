<trans-unit id="sb52c11c237a86135">
  <source>PB Test</source>
  <target>Test de PB</target>
</trans-unit>
<trans-unit id="s0939e731bb3e9ec3">
  <source>This guided test will determine your maximum breath-hold time. The result is used to generate your CO2 and O2 training tables.</source>
  <target>Ce test guid&#233; d&#233;termine le temps d'apn&#233;e maximum et g&#233;n&#232;re les tables d'entra&#238;nement CO2 et O2.</target>
</trans-unit>
<trans-unit id="s490ec5961a702c61">
  <source>The test consists of:</source>
  <target>Le test comprend :</target>
</trans-unit>
<trans-unit id="h661d548e7aae9319">
  <source>1. 2-minute relaxation phase<x id="0" equiv-text="&lt;br&gt;"/>
            2. <x id="1" equiv-text="${WARMUP_COUNT}"/> warm-up holds at 50% estimated max<x id="2" equiv-text="&lt;br&gt;"/>
            3. Final maximum breath hold</source>
  <target>1. Phase de relaxation de 2 minutes<x id="0" equiv-text="&lt;br&gt;"/>
            2. <x id="1" equiv-text="${WARMUP_COUNT}"/> apn&#233;es d'&#233;chauffement &#224; 50 % du maximum estim&#233;<x id="2" equiv-text="&lt;br&gt;"/>
            3. Apn&#233;e maximale finale</target>
</trans-unit>
<trans-unit id="s307a9c8dda7239d8">
  <source>Estimated max hold (seconds)</source>
  <target>Apn&#233;e maximale estim&#233;e (secondes)</target>
