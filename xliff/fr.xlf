<trans-unit id="s8b36bf8e360dc951">
  <source>Safety Notice</source>
  <target>Avis de s&#233;curit&#233;</target>
</trans-unit>
<trans-unit id="hed296358d43bfc35">
  <source>Breath-hold training carries inherent risks. Before using this app, please
                  be aware of the following:</source>
  <target>L'entra&#238;nement en apn&#233;e comporte des risques inh&#233;rents. Avant d'utiliser cette application, veuillez prendre connaissance des points suivants :</target>
</trans-unit>
<trans-unit id="hf16a61279a336cea">
  <source><x id="0" equiv-text="&lt;strong&gt;"/>Never train in water alone<x id="1" equiv-text="&lt;/strong&gt;"/> - dry (on land) training is recommended for solo practice</source>
  <target><x id="0" equiv-text="&lt;strong&gt;"/>Ne vous entra&#238;nez jamais dans l'eau seul(e)<x id="1" equiv-text="&lt;/strong&gt;"/> - l'entra&#238;nement &#224; sec est recommand&#233; pour la pratique en solo</target>
</trans-unit>
<trans-unit id="h6470f74dceda4fd1">
  <source><x id="0" equiv-text="&lt;strong&gt;"/>Never hyperventilate<x id="1" equiv-text="&lt;/strong&gt;"/> before breath holds</source>
  <target><x id="0" equiv-text="&lt;strong&gt;"/>Ne faites jamais d'hyperventilation<x id="1" equiv-text="&lt;/strong&gt;"/> avant les apn&#233;es</target>
</trans-unit>
<trans-unit id="h3012a826f30d777c">
  <source><x id="0" equiv-text="&lt;strong&gt;"/>Stop immediately<x id="1" equiv-text="&lt;/strong&gt;"/> if you feel dizzy, see spots, or experience strong involuntary contractions</source>
  <target><x id="0" equiv-text="&lt;strong&gt;"/>Arr&#234;tez imm&#233;diatement<x id="1" equiv-text="&lt;/strong&gt;"/> si vous ressentez des vertiges, voyez des points lumineux ou &#233;prouvez de fortes contractions involontaires</target>
</trans-unit>
<trans-unit id="h44d18e9784943915">
  <source><x id="0" equiv-text="&lt;strong&gt;"/>Do not train<x id="1" equiv-text="&lt;/strong&gt;"/> if fatigued, ill, or after consuming alcohol</source>
  <target><x id="0" equiv-text="&lt;strong&gt;"/>Ne vous entra&#238;nez pas<x id="1" equiv-text="&lt;/strong&gt;"/> si vous &#234;tes fatigu&#233;(e), malade ou apr&#232;s avoir consomm&#233; de l'alcool</target>
</trans-unit>
<trans-unit id="h9523acd95d3d7a06">
  <source><x id="0" equiv-text="&lt;strong&gt;"/>Consult a doctor<x id="1" equiv-text="&lt;/strong&gt;"/> if you have cardiovascular, respiratory, or neurological conditions</source>
  <target><x id="0" equiv-text="&lt;strong&gt;"/>Consultez un m&#233;decin<x id="1" equiv-text="&lt;/strong&gt;"/> si vous souffrez de troubles cardiovasculaires, respiratoires ou neurologiques</target>
</trans-unit>
